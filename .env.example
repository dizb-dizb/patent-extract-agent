# 双模型策略：规则核心用高质量模型，普通分割用高性能模型

# 方案 A：Gemini（推荐）
# GEMINI_API_KEY=your-gemini-api-key
# 规则核心（规则提取、证据链、构词推导）：高质量模型
# GEMINI_QUALITY_MODEL=gemini-3.1-pro-preview
# 普通分割（标注、翻译）：高性能模型
# GEMINI_PERFORMANCE_MODEL=gemini-3-flash-preview

# 方案 B：DeepSeek（规则核心）+ 快速模型（普通分割）
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_MODEL=deepseek-chat
# FAST_MODEL_URL=https://api.siliconflow.cn/v1
# FAST_MODEL_API_KEY=sk-xxx
# FAST_MODEL=Qwen/Qwen2.5-7B-Instruct

# 方案 C：仅单一模型（quality 与 performance 共用）
# 仅 DEEPSEEK 或 仅 FAST_MODEL 时，两种任务共用同一模型

# ---- Multi-Tier Cascade Verification ----
# Tier 2: 学术 API（PubChem/Europe PMC/ArXiv），默认开启
# ENABLE_TIER2_ACADEMIC=1
# Tier 3: 跨语言检索（需 LLM 翻译），默认开启；无 LLM 时可关闭
# ENABLE_TIER3_CROSS_LINGUAL=1
# Tier 4: 构词推导（需 LLM），默认开启；无 LLM 时用规则生成
# ENABLE_TIER4_DERIVATION=1
# 证据知识链：假设->佐证->构词规则->定论（替代简单 derivation，输出高信息密度格式供微调）
# ENABLE_EVIDENCE_CHAIN=1
# PubMed（可选）: 若使用 PubMed 替代 Europe PMC，需配置
# PUBMED_TOOL=patent-agent
# PUBMED_EMAIL=your@email.com

# ---- Cloud GPU (AutoDL / SeetaCloud / RunPod) via SSH ----
# AutoDL 示例：在控制台创建实例后，复制 SSH 地址与端口
# CLOUD_SSH_HOST=connect.westb.seetacloud.com
# CLOUD_SSH_PORT=12345
# CLOUD_SSH_USER=root
# CLOUD_SSH_KEY_PATH=C:\Users\你\.ssh\id_rsa
# CLOUD_REMOTE_WORKDIR=/root/Graduation-Project
# CLOUD_REMOTE_PYTHON=python3
# 激活 conda 环境（AutoDL 上执行 setup_autodl.sh 后）
# CLOUD_REMOTE_SETUP_CMD=source /root/miniconda3/etc/profile.d/conda.sh && conda activate patent-agent
